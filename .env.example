# EMR Timestamp Archaeologist - 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# ============================================================
# API 配置（必需）
# ============================================================

# LLM 服务提供商: openai 或 anthropic
EMR_API_PROVIDER=anthropic

# API Key（anthropic 或 openai）
EMR_API_KEY=sk-ant-your-api-key-here

# 模型名称
# Anthropic: claude-sonnet-4-20250514, claude-3-5-sonnet-20240620
# OpenAI: gpt-4o-mini, gpt-4o
EMR_API_MODEL=claude-sonnet-4-20250514

# 自定义 API 端点（可选，用于代理或自托管）
# EMR_API_BASE=https://api.anthropic.com

# ============================================================
# LLM 配置
# ============================================================

# 是否启用 LLM 分析
EMR_LLM_ENABLED=true

# 生成温度 (0.0-1.0)
EMR_LLM_TEMPERATURE=0.3

# 最大 Token 数
EMR_LLM_MAX_TOKENS=4096

# API 超时（秒）
EMR_LLM_TIMEOUT=60

# ============================================================
# 检测器配置
# ============================================================

# 批处理时间相同阈值（秒）
EMR_BATCH_THRESHOLD=60

# 夜间时段（小时，24小时制）
EMR_NIGHT_START=22
EMR_NIGHT_END=5

# ============================================================
# 通用配置
# ============================================================

# 详细输出
EMR_VERBOSE=false

# 日志级别: DEBUG, INFO, WARNING, ERROR
EMR_LOG_LEVEL=INFO
